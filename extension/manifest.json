{
  "manifest_version": 3,
  "name": "Add to Workspace",
  "version": "1.0",

  "permissions": ["contextMenus", "scripting", "storage"],

  "host_permissions": ["<all_urls>", "http://127.0.0.1:5000/*"],

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/toast.js"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Workspace"
  }
}
